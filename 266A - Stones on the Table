// https://codeforces.com/problemset/problem/266/A
#include <iostream>

using namespace std;
int main(){
    int stone;
    string s;
    cin >> stone >> s;
    int count = 0;
    for(int i=0; i<s.length(); i++){
        if(s[i] == s[i+1]){
            count++;
        }
    }
    cout << count << endl;
    return 0;
}
