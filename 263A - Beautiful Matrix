#include <iostream>
#include <cmath> // Required for abs()

using namespace std;

int main() {
    int val;
    int moves = 0;

    // Scan the 5x5 matrix
    for (int i = 0; i < 5; i++) {
        for (int j = 0; j < 5; j++) {
            cin >> val;
            if (val == 1) {
                // Calculate distance from center (2, 2)
                moves = abs(i - 2) + abs(j - 2);
            }
        }
    }

    cout << moves << endl;
    return 0;
}
