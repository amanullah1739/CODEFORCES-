
// https://codeforces.com/problemset/problem/236/A
#include <iostream>
#include <unordered_set>
using namespace std;
int main(){
    unordered_set<char> hash;
    string s;
    cin >> s;
    int count = 0;
    
    for(char ch : s){
        if(hash.find(ch) == hash.end()){
            hash.insert(ch);
            count++;
        }
    }
    if(count%2==0){
        cout << "CHAT WITH HER!";
    }
    else{
        cout << "IGNORE HIM!";
    }
    // cout << count;
    return 0;
    
}
