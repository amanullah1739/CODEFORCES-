#include <iostream>
#include <string>
#include <algorithm>
// https://codeforces.com/problemset/problem/266/B

using namespace std;

int main() {
    int n, t;
    string s;
    if (cin >> n >> t >> s) {
        while (t--) {
            for (int i = 0; i < n - 1; ) {
                if (s[i] == 'B' && s[i + 1] == 'G') {
                    swap(s[i], s[i + 1]);
                    i += 2; // Skip next index to prevent chain-swapping in the same second
                } else {
                    i++;
                }
            }
        }
        cout << s << endl;
    }
    return 0;
}

    
    
    
    return 0;
}
